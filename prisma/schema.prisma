generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- 管理员 ----------
model User {
  id           String @id @default(cuid())
  username     String @unique
  passwordHash String
  displayName  String
}

// ---------- 活动 ----------
model Event {
  id                   String         @id @default(cuid())
  title                String
  summary              String
  content              String         // Markdown 正文
  coverImage           String         @default("")  // 外部图片 URL
  startDate            DateTime
  endDate              DateTime
  location             String
  maxParticipants      Int?
  registrationDeadline DateTime?
  status               String         @default("draft") // draft | published | cancelled | completed
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  registrations        Registration[]
}

// ---------- 报名 ----------
model Registration {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  studentId String
  phone     String
  email     String   @default("")
  notes     String   @default("")
  status    String   @default("pending") // pending | confirmed | cancelled
  createdAt DateTime @default(now())

  @@unique([eventId, studentId])
}

// ---------- 合作伙伴 ----------
model Partner {
  id        String   @id @default(cuid())
  name      String
  logoUrl   String   @default("")
  link      String   @default("")
  category  String   @default("COMMUNITY") // ENTERPRISE | UNIVERSITY | COMMUNITY
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- 新闻/推文（公众号外链） ----------
model Article {
  id          String    @id @default(cuid())
  title       String
  summary     String
  link        String    // 公众号文章链接
  coverImage  String    @default("")  // 封面图片 URL，比例 2.35:1
  status      String    @default("draft") // draft | published
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
